{
  "name": "@worklist/oss-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "crypto-web:typecheck": "cd packages/crypto-web && bun run typecheck",
    "crypto-web:test": "cd packages/crypto-web && bun run test",
    "crypto-web:verify-wasm": "cd packages/crypto-web && bun run verify:wasm",
    "test": "bun run crypto-web:typecheck && bun run crypto-web:test && bun run crypto-web:verify-wasm"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
